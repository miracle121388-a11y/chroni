# Copy this file to .env at the repository root for local development.
# Never commit a real API key.
CHRONI_LLM_ENABLED=1
CHRONI_LLM_MODE=custom
CHRONI_LLM_BASE_URL=https://api.deepseek.com
CHRONI_LLM_MODEL=deepseek-v4-flash
CHRONI_LLM_API_KEY=replace-with-your-deepseek-api-key

# To test the managed beta gateway locally, replace the four values above with:
# CHRONI_LLM_MODE=managed
# CHRONI_LLM_BASE_URL=https://api-getchroni.zeabur.app/v1
# CHRONI_LLM_MODEL=chroni-beta
# CHRONI_LLM_API_KEY=replace-with-your-chroni-beta-access-code

# Optional local HTTP API settings:
# CHRONI_API_PORT=8765
# CHRONI_API_TOKEN=replace-with-a-long-random-local-token
# CHRONI_API_ALLOWED_ORIGIN=http://127.0.0.1:3000
